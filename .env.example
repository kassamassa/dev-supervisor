# ────────────────────────────────────────
# dev-supervisor 環境変数一覧
# Railway の Variables に全て設定すること
# ────────────────────────────────────────

# Supabase
SUPABASE_KEY=eyJhbGci...          # Supabase anon key

# GitHub
GITHUB_TOKEN=ghp_...              # Personal Access Token (repo スコープ)
GITHUB_WEBHOOK_SECRET=            # GitHub webhook 署名検証（任意）

# Dify
DIFY_TASK_EXEC_KEY=app-...        # ②タスク実行ワークフローのAPIキー
DIFY_CODEGEN_KEY=app-...          # コード生成専用ワークフローのAPIキー（brainstorm含む）

# Railway（パイプライン自動デプロイ用）
RAILWAY_TOKEN=                    # Railway API Token

# Vercel（パイプライン自動デプロイ用）
VERCEL_TOKEN=                     # Vercel API Token

# ────────────────────────────────────────
# フロントエンド（frontend/.env）
# Vercel の Environment Variables に設定
# ────────────────────────────────────────
# VITE_SUPABASE_URL=https://thfthbblfsjhyqcinyms.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGci...
# VITE_RAILWAY_URL=https://dev-supervisor-production.up.railway.app
